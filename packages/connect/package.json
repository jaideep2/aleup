{
  "name": "@aleup/connect",
  "version": "0.1.0",
  "description": "OAuth + save-back write clients for Google Drive, OneDrive (Graph), Box, and Dropbox. Server-side, fetch-only, zero vendor deps.",
  "license": "UNLICENSED",
  "type": "module",
  "sideEffects": false,
  "files": ["dist"],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@aleup/core": "^0.1.0"
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com"
  },
  "engines": {
    "node": ">=20"
  }
}
