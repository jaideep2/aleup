{
  "name": "aleup-monorepo",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,css,mjs}\"",
    "gen-licenses": "node scripts/gen-third-party-licenses.mjs",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release:snapshot": "changeset version --snapshot dev && pnpm -r publish --tag dev --no-git-checks"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.14.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.3.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "turbo": "^2.1.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.14.0",
    "vitest": "^2.1.5"
  }
}
